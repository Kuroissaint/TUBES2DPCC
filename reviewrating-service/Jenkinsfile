pipeline {
    agent any

    environment {
        SERVICE_NAME = "review-rating-service" 
        DOCKER_IMAGE = "my-registry/${SERVICE_NAME}:${env.BUILD_NUMBER}"
    }

    stages {
        stage('1. Checkout Repo') {
            steps {
                checkout scm
            }
        }

        stage('2. Unit Tests') {
            steps {
                sh 'go test ./... -v'
            }
        }

        stage('3. Lint / Vet') {
            steps {
                sh 'go vet ./...'
            }
        }

        stage('4. Build Image (Lokal)') {
            steps {
                sh "docker build -t ${DOCKER_IMAGE} ."
            }
        }

        stage('5. Functional Tests') {
            steps {
                sh 'go test -tags=functional ./... -v'
            }
        }

        stage('6. Push Image') {
            steps {
                sh "docker push ${DOCKER_IMAGE}"
            }
        }

        stage('7. Deploy di Kubernetes') {
            steps {
                sh "kubectl apply -f k8s/"
                sh "kubectl rollout restart deployment/${SERVICE_NAME}"
            }
        }

        stage('8. Verify') {
            steps {
                sh "kubectl rollout status deployment/${SERVICE_NAME}"
                sh "kubectl get pods -l app=${SERVICE_NAME}"
            }
        }
    }

    post {
        success {
            echo "Successfully deployed ${SERVICE_NAME} version ${env.BUILD_NUMBER}"
        }
        failure {
            echo "Deployment failed! Check logs."
        }
    }
}